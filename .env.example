# ── Provider selection ────────────────────────────────────────────────────────
# "claude" (default) uses the Claude Agent SDK
# "vercel"           uses the Vercel AI SDK with Gemini models
AGENT_PROVIDER=claude

# ── Claude (default provider) ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Vercel AI SDK + Google Gemini provider ────────────────────────────────────
# AGENT_PROVIDER=vercel
# GOOGLE_GENERATIVE_AI_API_KEY=your-key-here  # from aistudio.google.com (free)
# TAVILY_API_KEY=your-tavily-key-here          # from tavily.com (free tier)
# GEMINI_MODEL=gemini-2.0-flash                # default

# ── Infrastructure ────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@ep-xxx...neon.tech/neondb?sslmode=require
EMBEDDING_DIMENSION=384
VERCEL_AI_API_KEY=your-vercel-key-here